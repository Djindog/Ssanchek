{
  "installCommand": "npm install",
  "buildCommand": "npx prisma generate && cd frontend && npm install && npm run build",
  "outputDirectory": "frontend/dist",
  "functions": {
    "api/crawl-result.js": { "maxDuration": 30 },
    "api/optimize.js": { "maxDuration": 60 }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
